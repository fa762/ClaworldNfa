{
  "name": "clawworld-contracts",
  "version": "1.0.0",
  "description": "Claw Civilization Universe - Smart Contracts based on BAP-578 NFA Standard",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "coverage": "npx hardhat coverage",
    "build": "npm --prefix frontend run build",
    "build:testnet": "npm --prefix frontend run build:testnet",
    "build:mainnet": "npm --prefix frontend run build:mainnet",
    "deploy:local": "npx hardhat run scripts/deploy-phase1.ts --network localhost",
    "deploy:testnet": "npx hardhat run scripts/deploy-phase1.ts --network bscTestnet",
    "node": "npx hardhat node",
    "clean": "npx hardhat clean",
    "size": "npx hardhat size-contracts",
    "runner:autonomy": "node -r ts-node/register/transpile-only openclaw/start-autonomy-runner.ts",
    "runner:autonomy:once": "node -r ts-node/register/transpile-only openclaw/start-autonomy-runner.ts --once",
    "runner:autonomy:check": "node -r ts-node/register/transpile-only openclaw/start-autonomy-runner.ts --check-env",
    "migrate:autonomy:battle-royale:mainnet": "npx hardhat run scripts/migrate-battle-royale-autonomy-mainnet.ts --network bscMainnet",
    "smoke:battle-royale:autonomy:mainnet": "npx hardhat run scripts/smoke-battle-royale-autonomy-mainnet.ts --network bscMainnet",
    "watch:battle-royale": "node -e \"process.env.HARDHAT_NETWORK='bscMainnet'; process.env.BATTLE_ROYALE_WATCH_MODE='serve'; require('ts-node/register/transpile-only'); require('./scripts/watch-battle-royale-reveal.ts');\"",
    "watch:battle-royale:once": "node -e \"process.env.HARDHAT_NETWORK='bscMainnet'; process.env.BATTLE_ROYALE_WATCH_MODE='once'; require('ts-node/register/transpile-only'); require('./scripts/watch-battle-royale-reveal.ts');\"",
    "watch:battle-royale:check": "node -e \"process.env.HARDHAT_NETWORK='bscMainnet'; process.env.BATTLE_ROYALE_WATCH_MODE='check-env'; require('ts-node/register/transpile-only'); require('./scripts/watch-battle-royale-reveal.ts');\""
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "@nomicfoundation/hardhat-chai-matchers": "^1.0.6",
    "@nomicfoundation/hardhat-verify": "^2.0.12",
    "@nomiclabs/hardhat-ethers": "^2.2.3",
    "@openzeppelin/contracts": "^4.9.6",
    "@openzeppelin/contracts-upgradeable": "^4.9.6",
    "@openzeppelin/hardhat-upgrades": "^1.28.0",
    "@typechain/ethers-v5": "^11.1.2",
    "@typechain/hardhat": "^7.0.0",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "@types/node-fetch": "^2.6.13",
    "chai": "^4.3.7",
    "dotenv": "^16.5.0",
    "ethers": "^5.7.2",
    "form-data": "^4.0.5",
    "hardhat": "^2.24.2",
    "hardhat-contract-sizer": "^2.10.0",
    "hardhat-gas-reporter": "^1.0.10",
    "https-proxy-agent": "^5.0.1",
    "local-cors-proxy": "^1.1.0",
    "node-fetch": "^2.7.0",
    "solidity-coverage": "^0.8.13",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.3.3",
    "undici": "^7.24.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "global-agent": "^4.1.3",
    "solc": "^0.8.26"
  }
}
