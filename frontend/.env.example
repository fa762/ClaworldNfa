# Network Configuration
NEXT_PUBLIC_CHAIN_ID=97

# RPC
NEXT_PUBLIC_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# Contract Addresses (fill after deployment)
NEXT_PUBLIC_CLAWNFA_ADDRESS=0x...
NEXT_PUBLIC_CLAWROUTER_ADDRESS=0x...
NEXT_PUBLIC_WORLDSTATE_ADDRESS=0x...
NEXT_PUBLIC_GENESIS_VAULT_ADDRESS=0x...
NEXT_PUBLIC_CLW_TOKEN_ADDRESS=0x...
NEXT_PUBLIC_FLAP_PORTAL_ADDRESS=0x5bEacaF7ABCbB3aB280e80D007FD31fcE26510e9
NEXT_PUBLIC_PANCAKE_ROUTER_ADDRESS=0x...

# WalletConnect
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# IPFS
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs/

# Event scanning start block (set to deployment block)
NEXT_PUBLIC_DEPLOY_BLOCK=0

# Server-only Claworld API bridge.
# Browser -> Next API -> your backend API server.
# The backend loads NFA identity/context, handles chat intent, prepares chain actions,
# and returns message/action cards. Leave empty in local UI work to use fallback cards.
CLAWORLD_API_URL=
CLAWORLD_CHAT_PATH=/chat/{tokenId}/send
CLAWORLD_API_TOKEN=

# Backward-compatible aliases. Prefer the CLAWORLD_API_* names above.
CLAWORLD_BACKEND_API_URL=
CLAWORLD_BACKEND_CHAT_PATH=/chat/{tokenId}/send
CLAWORLD_BACKEND_API_TOKEN=
