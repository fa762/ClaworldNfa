# ========================================
# 测试网环境 (BSC Testnet)
# 连接真实测试网合约
# npm run dev:testnet
# ========================================
NEXT_PUBLIC_APP_ENV=testnet

# BSC Testnet
NEXT_PUBLIC_CHAIN_ID=97
NEXT_PUBLIC_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# Contract Addresses (部署后填入真实地址)
NEXT_PUBLIC_CLAWNFA_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_CLAWROUTER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_WORLDSTATE_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_GENESIS_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_CLW_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_FLAP_PORTAL_ADDRESS=0x5bEacaF7ABCbB3aB280e80D007FD31fcE26510e9
NEXT_PUBLIC_PANCAKE_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000

# WalletConnect - Get your project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=placeholder

# IPFS
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs/

# Event scanning start block (set to deployment block)
NEXT_PUBLIC_DEPLOY_BLOCK=0
