NEXT_PUBLIC_APP_ENV=mainnet

# BSC Mainnet
NEXT_PUBLIC_CHAIN_ID=56
NEXT_PUBLIC_RPC_URL=https://bsc-dataseed1.binance.org

# Contract Addresses (部署后填入真实主网地址)
