PRIVATE_KEY=your_private_key_here
REPORT_GAS=false
BSCSCAN_API_KEY=your_bscscan_api_key

# Frontend chat BFF -> project backend API. Keep real tokens server-side only.
CLAWORLD_API_URL=
CLAWORLD_CHAT_PATH=/chat/{tokenId}/send
CLAWORLD_API_TOKEN=

# Optional direct OpenAI-compatible fallback used only by the Next.js server.
CLAWORLD_CHAT_MODEL_BASE_URL=
CLAWORLD_CHAT_MODEL_API_KEY=
CLAWORLD_CHAT_MODEL_NAME=

# Optional override for backend web/search tools.
# Default behavior: enabled when CLAWORLD_API_URL is configured.
# Set to 0 only if you want to disable backend search for chat.
CLAWORLD_ENABLE_WEB_TOOLS=1
